# Host/port of your Mode-S receiver's Beast TCP output
# readsb/dump1090-fa default: port 30005
BEAST_HOST=localhost
BEAST_PORT=30005

# MLAT Beast streams — comma-separated list of server entries.
# Two formats per entry:
#   Name@host:port   — explicit host (use when host differs from BEAST_HOST)
#   Name:port        — host defaults to BEAST_HOST
# The Name is shown in the MLAT badge tooltip in the live table.
# MLAT_SERVERS=ADSBx@adsbpi:30158,FlightAware:30105,Airplanes:30157

# Receiver coordinates — enables CPR position decoding (range, polar plot, etc.)
# Without these, global decode still works but only after receiving both even+odd CPR frames
# RECEIVER_LAT=51.5
# RECEIVER_LON=-0.1

# Remove aircraft from the live table after this many seconds without a message
AIRCRAFT_TIMEOUT=60

# Your home country — military aircraft from other countries are flagged "foreign military"
HOME_COUNTRY=United Kingdom

# Aircraft seen in fewer than this many distinct sessions (gap > 1hr) are flagged "rare"
RARE_THRESHOLD=5

# How many days to keep per-minute data before pruning (daily rollups are kept forever)
MINUTE_STATS_RETENTION_DAYS=30

# SQLite database path (default: backend/data/adsb.db)
# DB_PATH=data/adsb.db

# Nightly backup — set BACKUP_PATH to a directory to enable.
# One file per day named adsb_backup_YYYY-MM-DD.db; runs at local midnight.
# BACKUP_PATH=/path/to/backup/dir
# BACKUP_RETAIN=7

# Minimum messages before an aircraft is written to the registry.
# Filters bogus ICAO addresses from CRC decoding errors. Set 0 to disable.
# A confirmed ADSBExchange or hexdb hit bypasses this check regardless.
# GHOST_FILTER_MSGS=5

# Enable verbose enrichment logging (new aircraft lookups, hexdb outcomes)
# DEBUG_ENRICHMENT=true

# ---------------------------------------------------------------------------
# Pi 4 / SD card tuning (safe defaults — uncomment to override)
# ---------------------------------------------------------------------------
# synchronous=NORMAL is safe with WAL; eliminates most fsync() calls on SD.
# Use FULL only if the Pi has an unreliable power supply.
# SQLITE_SYNCHRONOUS=NORMAL

# How often to recalculate aircraft type rarity (seconds).
# The rare flag changes only when a new type appears — daily is sufficient.
# 21600=6h (default), 3600=1h, 86400=24h
# RARITY_RECALC_SECONDS=21600

# How often to flush buffered aircraft_registry upserts (seconds).
# Reduces SD writes from ~100/minute to ~100 every 5 minutes at 100 live aircraft.
# REGISTRY_FLUSH_SECONDS=300

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
# ntfy.sh push notifications (free, no account needed for public topics)
# NTFY_URL=https://ntfy.sh/your-unique-topic

# Email via SMTP (Gmail example: host=smtp.gmail.com, port=587, use App Password)
# NOTIFY_EMAIL_TO=you@example.com
# NOTIFY_EMAIL_FROM=sender@example.com
# NOTIFY_SMTP_HOST=localhost
# NOTIFY_SMTP_PORT=587    # 587=STARTTLS (default), 465=SSL
# NOTIFY_SMTP_USER=
# NOTIFY_SMTP_PASS=

# Trigger switches (NOTIFY_EMERGENCY defaults true; others default false)
# Individual aircraft watchlist is managed in the Settings tab of the UI.
# NOTIFY_EMERGENCY=true
# NOTIFY_ACAS=false
# NOTIFY_MILITARY=false
# NOTIFY_INTERESTING=false
